// test_arithmetic.rex — integer arithmetic operators: +, -, *, /, %
int a
:a = 20

int add_result
:add_result = a + 5
output add_result

int sub_result
:sub_result = a - 3
output sub_result

int mul_result
:mul_result = a * 3
output mul_result

int div_result
:div_result = a / 4
output div_result

int mod_result
:mod_result = a % 7
output mod_result
